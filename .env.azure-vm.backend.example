# Azure VM backend runtime environment
# Replace <DATA_VM_PRIVATE_IP> with the actual value from:
#   terraform output data_vm_private_ips
# Replace <APP_GATEWAY_PUBLIC_HOST> with the Application Gateway public IP or DNS name.

APP_ENV=production
CORS_ORIGINS=http://<APP_GATEWAY_PUBLIC_HOST>
JWT_SECRET_KEY=change-this-before-production

DATABASE_URL=postgresql+psycopg://spendpilot:change-this-db-password@<DATA_VM_PRIVATE_IP>:5432/spend_control
OLLAMA_BASE_URL=http://<DATA_VM_PRIVATE_IP>:11434
OLLAMA_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT=30

EXPENSE_SERVICE_URL=http://expense-service:8001
AI_SERVICE_URL=http://ai-service:8002
RECEIPT_REQUIRED_THRESHOLD=75

UPLOAD_DIR=/data/uploads
