# Azure VMSS backend runtime environment
# Replace <POSTGRES_FQDN> with:
#   terraform output postgres_fqdn
# Replace <OLLAMA_PRIVATE_LB_IP> with:
#   terraform output ollama_private_load_balancer_ip
# Replace <APP_GATEWAY_PUBLIC_HOST> with the Application Gateway public IP or DNS name.

APP_ENV=production
CORS_ORIGINS=http://20.207.66.136
JWT_SECRET_KEY=dev-secret-change-me

DATABASE_URL=postgresql+psycopg://spendpilot:spendpilot@<POSTGRES_FQDN>:5432/spend_control?sslmode=require
OLLAMA_BASE_URL=http://<OLLAMA_PRIVATE_LB_IP>:11434
OLLAMA_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT=30

EXPENSE_SERVICE_URL=http://expense-service:8001
AI_SERVICE_URL=http://ai-service:8002
RECEIPT_REQUIRED_THRESHOLD=75

UPLOAD_DIR=/data/uploads
