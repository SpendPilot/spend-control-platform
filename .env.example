# Local Docker Compose environment.
# For Azure VM backend mode, use `.env.azure-vm.backend.example` instead.

# PostgreSQL Configuration
POSTGRES_USER=spendcontrol
POSTGRES_PASSWORD=spendcontrol
POSTGRES_DB=spend_control
DATABASE_URL=postgresql+psycopg://spendcontrol:spendcontrol@postgres:5432/spend_control

# Application Configuration
APP_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# JWT Configuration
JWT_SECRET_KEY=dev-secret-change-me

# Service URLs (for backend inter-service communication)
EXPENSE_SERVICE_URL=http://expense-service:8001
AI_SERVICE_URL=http://ai-service:8002

# Expense Service Configuration
UPLOAD_DIR=/data/uploads

# AI Service Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT=30

# Control Service Configuration
RECEIPT_REQUIRED_THRESHOLD=75

# Frontend Configuration
NODE_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
